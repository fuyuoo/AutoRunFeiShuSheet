# ============================================================
# 配置文件模板
# 复制此文件为 config.yaml 并填入实际值
# ============================================================

tushare:
  token: "your_tushare_token"  # Tushare Pro Token

feishu:
  app_id: "your_app_id"
  app_secret: "your_app_secret"
  bitable:
    app_token: "your_app_token"  # 多维表格 app_token
    table_id: "your_table_id"    # 数据表 table_id
    code_column: "代码"
    type_column: "股票类型"

field_mapping:
  "日线J": "daily_kdj_j"
  "日线CCI": "daily_cci"
  "日线BOLL": "daily_boll_middle"
  "日线BOLL上轨": "daily_boll_upper"
  "日线BOLL下轨": "daily_boll_lower"
  "日收盘价": "close"
  "周线J": "weekly_kdj_j"
  "周线CCI": "weekly_cci"
  "周线BOLL": "weekly_boll_middle"
  "周线BOLL上轨": "weekly_boll_upper"
  "周线BOLL下轨": "weekly_boll_lower"
  "周收盘价": "weekly_close"
  "月线J": "monthly_kdj_j"
  "月线CCI": "monthly_cci"
  "月线BOLL": "monthly_boll_middle"
  "月线BOLL上轨": "monthly_boll_upper"
  "月线BOLL下轨": "monthly_boll_lower"
  "月收盘价": "monthly_close"
  "更新时间": "trade_date"

sync:
  history_days: 500
  indicators:
    kdj:
      n: 9
      m1: 3
      m2: 3
    cci:
      n: 14
    boll:
      n: 20
      k: 2

cache:
  enabled: true
  dir: "data/cache"
